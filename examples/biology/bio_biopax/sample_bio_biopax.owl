<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:bp="http://www.biopax.org/release/biopax-level3.owl#" 
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <bp:Pathway rdf:ID="Glycolysis">
    <bp:displayName>Glycolysis</bp:displayName>
    <bp:pathwayComponent rdf:resource="#Glucose_to_Glucose6Phosphate"/>
  </bp:Pathway>

  <bp:BiochemicalReaction rdf:ID="Glucose_to_Glucose6Phosphate">
    <bp:displayName>Glucose + ATP → Glucose-6-phosphate + ADP</bp:displayName>
    <bp:left rdf:resource="#Glucose"/>
    <bp:left rdf:resource="#ATP"/>
    <bp:right rdf:resource="#Glucose6Phosphate"/>
    <bp:right rdf:resource="#ADP"/>
    <bp:controller rdf:resource="#Hexokinase"/>
  </bp:BiochemicalReaction>

  <bp:SmallMolecule rdf:ID="Glucose">
    <bp:displayName>Glucose</bp:displayName>
    <bp:chemicalFormula>C6H12O6</bp:chemicalFormula>
  </bp:SmallMolecule>

  <bp:SmallMolecule rdf:ID="ATP">
    <bp:displayName>ATP</bp:displayName>
    <bp:chemicalFormula>C10H16N5O13P3</bp:chemicalFormula>
  </bp:SmallMolecule>

  <bp:SmallMolecule rdf:ID="Glucose6Phosphate">
    <bp:displayName>Glucose-6-phosphate</bp:displayName>
    <bp:chemicalFormula>C6H13O9P</bp:chemicalFormula>
  </bp:SmallMolecule>

  <bp:SmallMolecule rdf:ID="ADP">
    <bp:displayName>ADP</bp:displayName>
    <bp:chemicalFormula>C10H15N5O10P2</bp:chemicalFormula>
  </bp:SmallMolecule>

  <bp:Protein rdf:ID="Hexokinase">
    <bp:displayName>Hexokinase</bp:displayName>
  </bp:Protein>
</rdf:RDF>