<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/diseases#"
     xml:base="http://example.org/diseases"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

<owl:Ontology rdf:about="http://example.org/diseases"/>

<owl:Class rdf:about="http://example.org/diseases#Disease"/>
<owl:Class rdf:about="http://example.org/diseases#Symptom"/>
<owl:Class rdf:about="http://example.org/diseases#Treatment"/>

<owl:ObjectProperty rdf:about="http://example.org/diseases#hasSymptom">
  <rdfs:domain rdf:resource="http://example.org/diseases#Disease"/>
  <rdfs:range rdf:resource="http://example.org/diseases#Symptom"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/diseases#hasTreatment">
  <rdfs:domain rdf:resource="http://example.org/diseases#Disease"/>
  <rdfs:range rdf:resource="http://example.org/diseases#Treatment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://example.org/diseases#treatsSymptom">
  <rdfs:domain rdf:resource="http://example.org/diseases#Treatment"/>
  <rdfs:range rdf:resource="http://example.org/diseases#Symptom"/>
</owl:ObjectProperty>

<owl:NamedIndividual rdf:about="http://example.org/diseases#Flu">
  <rdf:type rdf:resource="http://example.org/diseases#Disease"/>
  <hasSymptom rdf:resource="http://example.org/diseases#Fever"/>
  <hasSymptom rdf:resource="http://example.org/diseases#Cough"/>
  <hasTreatment rdf:resource="http://example.org/diseases#Rest"/>
  <hasTreatment rdf:resource="http://example.org/diseases#Antiviral"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/diseases#Fever">
  <rdf:type rdf:resource="http://example.org/diseases#Symptom"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/diseases#Cough">
  <rdf:type rdf:resource="http://example.org/diseases#Symptom"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/diseases#Rest">
  <rdf:type rdf:resource="http://example.org/diseases#Treatment"/>
  <treatsSymptom rdf:resource="http://example.org/diseases#Fever"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/diseases#Antiviral">
  <rdf:type rdf:resource="http://example.org/diseases#Treatment"/>
  <treatsSymptom rdf:resource="http://example.org/diseases#Fever"/>
  <treatsSymptom rdf:resource="http://example.org/diseases#Cough"/>
</owl:NamedIndividual>

</rdf:RDF>