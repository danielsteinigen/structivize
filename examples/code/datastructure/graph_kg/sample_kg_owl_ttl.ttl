@prefix : <http://example.org/urban#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:UrbanEntity rdf:type owl:Class .
:FundamentalForce rdf:type owl:Class .

:Park rdf:type owl:Class ;
    rdfs:subClassOf :UrbanEntity .

:Road rdf:type owl:Class ;
    rdfs:subClassOf :UrbanEntity .

:Building rdf:type owl:Class ;
    rdfs:subClassOf :UrbanEntity .

:Gravity rdf:type owl:Class ;
    rdfs:subClassOf :FundamentalForce .

:Electromagnetism rdf:type owl:Class ;
    rdfs:subClassOf :FundamentalForce .

:influencedBy rdf:type owl:ObjectProperty ;
    rdfs:domain :UrbanEntity ;
    rdfs:range :FundamentalForce .

:CentralPark rdf:type :Park ;
    :influencedBy :Gravity .

:MainStreet rdf:type :Road ;
    :influencedBy :Gravity .

:CityHall rdf:type :Building ;
    :influencedBy :Gravity, :Electromagnetism .